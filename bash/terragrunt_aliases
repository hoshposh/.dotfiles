	kc_env rollout status deployment "$tenant-srv-rpt" -n applications --timeout=120s && \
	ut get-version --k8s-service k8s-rpt && \
	ut apply --tenant-context services/k8s-wf-amq && \
	ut apply --tenant-context services/k8s-wf && \
	kc_env rollout status deployment "$tenant-wf-srv" -n workflow --timeout=120s && \
