		echo "ERROR: Missing tenant argument"
		return 1
	fi
	ut start-maintenance -w && \
	ut scale-pods -w --wait --all -p 0 --ignore "k8s-amq,k8s-wf-amq" && \
	ut dms stop-migration-task && \
	ut kubectl patch cronjob "$tenant-srv-ig-dbinit-audit-job-v1" -n applications -p '{"spec" : {"suspend" : true }}' && \
	ut db-backup -w --db-snapshot-suffix "pre-440" && \
	ut apply --tenant-context data-stores/aurora-postgresql && \
	ut apply --tenant-context services/migration-script && \
	ut apply --tenant-context services/ig-dbinit-job && \
	ut apply --tenant-context services/wf-dbinit-job && \
	ut apply --tenant-context services/k8s-amq && \
	ut apply --tenant-context services/k8s-ig && \
	kc_env rollout status deployment "$tenant-srv-ig" -n applications --timeout=120s && \
	ut get-version && \
