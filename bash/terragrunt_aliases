function copy_file_to_ig_pod {
  local -r local_file_path="$1"
  local -r remote_file_path="${2:-/tmp/}"

  if [[ ! -f "$local_file_path" ]]; then
    echo "ERROR: File not found: $local_file_path"
    return 1
  fi

  local -r application_name="$(grep "^\s*application_name\s*=" "services/k8s-ig/terragrunt.hcl" | sed 's/.*=//;s/\s//g' | sed 's|\"||g' | head -n1)" || {
    echo "Failed to get application_name from services/k8s-ig/terragrunt.hcl"
    return 1
  }

  if [[ -z "$application_name" ]]; then
    echo "ERROR: Failed to get the application name from services/k8s-ig/terragrunt.hcl"
    return 1
  fi

  kubectl auth can-i get pods -n applications || {
    echo "ERROR: You do not have permission to get pods in the applications namespace for the current cluster context: $(kubectl config current-context)"
    return 1
  }

  local -r pod_name="$(kubectl get pods -l app.kubernetes.io/name="$application_name" -n applications -o jsonpath="{.items[0].metadata.name}")" || {
    echo "ERROR: Failed to get the pod name for the application: $application_name"
    return 1
  }

  if [[ -z "$pod_name" ]]; then
    echo "ERROR: No pods found for the application: $application_name"
    return 1
  fi

  kubectl cp "$local_file_path" "$pod_name":"$remote_file_path" -n applications || {
    echo "ERROR: Failed to copy the file to the IG pod: $pod_name"
    return 1
  }

  echo "INFO: Successfully copied the file to the IG pod: $pod_name"
}
